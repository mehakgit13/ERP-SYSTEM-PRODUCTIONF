# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/erp_db
# Atlas:  mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/erp_db
MONGO_URI=mongodb://localhost:27017/erp_db

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string_in_production
JWT_EXPIRE=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Set this to your Vercel frontend URL in Render environment variables
# Example: https://your-erp-app.vercel.app
CLIENT_URL=http://localhost:3000
